# Server
PORT=3000
NODE_ENV=development

# Auth
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_EXPIRES_IN=7d

# Database (Turso / libSQL)
# For local dev: TURSO_DATABASE_URL=file:local.db
# For production: set via Vercel env vars
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=

# WhatsApp / SMS notification API (Phase 1.5 - optional, not required for MVP)
# FONNTE_TOKEN=
